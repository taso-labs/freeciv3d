{
    "enabled": true,
    "endpoint": "/llmsocket",
    "max_agents": 10,
    "allowed_origins": [
        "http://localhost:8003",
        "http://127.0.0.1:8003",
        "http://localhost:8080",
        "http://127.0.0.1:8080",
        "https://localhost:8003",
        "https://127.0.0.1:8003",
        "https://localhost:8080",
        "https://127.0.0.1:8080"
    ],
    "cache_config": {
        "ttl": 5,
        "max_size_kb": 4,
        "optimization_level": "high"
    },
    "validation": {
        "strict": true,
        "log_failures": true,
        "rate_limit": {
            "requests_per_second": 10,
            "burst_capacity": 100
        }
    },
    "capabilities": {
        "default": [
            "unit_move",
            "unit_build_city",
            "unit_explore",
            "city_production",
            "tech_research"
        ],
        "restricted": [
            "city_buy",
            "trade_route",
            "declare_war"
        ]
    },
    "authentication": {
        "require_api_token": true,
        "token_min_length": 10,
        "token_env_var": "LLM_API_TOKENS",
        "token_separator": ",",
        "allow_env_override": true
    },
    "performance": {
        "state_query_timeout_ms": 50,
        "action_timeout_ms": 30,
        "connection_timeout_s": 60
    },
    "logging": {
        "level": "INFO",
        "log_actions": true,
        "log_state_queries": true,
        "log_performance": true
    },
    "civserver": {
        "default_port": 6001,
        "multiplayer_ports": [6001, 6004, 6006, 6009],
        "singleplayer_ports": [6000, 6002, 6003, 6005, 6007, 6008]
    }
}
