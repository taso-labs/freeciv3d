# FreeCiv3D Environment Configuration
# Copy this file to .env and update with your settings

# ===================================
# LLM Gateway Configuration
# ===================================

# Cache HMAC Secret (required, min 64 characters)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
CACHE_HMAC_SECRET=your_64_character_hmac_secret_here_must_be_cryptographically_secure

# API Key Secret (required, min 32 characters)
# Generate with: python3 -c "import secrets; print(secrets.token_hex(16))"
API_KEY_SECRET=your_32_character_api_key_secret_here

# LLM API Tokens (comma-separated list)
# These tokens are used by LLM agents to authenticate
LLM_API_TOKENS=test-token-fc3d-001,test-token-fc3d-002,your-production-token

# Session Configuration
SESSION_TIMEOUT_SECONDS=3600
MAX_LLM_AGENTS=10
MAX_SESSIONS_PER_PLAYER=3

# Cache Configuration
CACHE_TTL_SECONDS=5
CACHE_COMPRESSION_THRESHOLD=1024
CACHE_COMPRESSION_LEVEL=6
CACHE_COMPRESSION_RATIO_THRESHOLD=0.8

# Rate Limiting
REQUESTS_PER_SECOND=10
BURST_CAPACITY=100

# ===================================
# Database Configuration
# ===================================

DB_HOST=127.0.0.1
DB_USER=docker
DB_PASSWORD=changeme
DB_NAME=freeciv_web

# ===================================
# Redis Configuration (Optional)
# ===================================

# Redis is used for distributed rate limiting and caching
# If not configured, in-memory alternatives will be used
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20
REDIS_HEALTH_CHECK_INTERVAL=30

# ===================================
# Development/Testing
# ===================================

# Enable debug logging
DEBUG=false

# API Key max age in days
API_KEY_MAX_AGE_DAYS=365

# Performance limits
MAX_CITIES_FOR_OPTIMIZATION=5