cmdlevel ctrl first
set nationset all
set compresstype xz
set maxplayers 100
set allowtake H1Ah1adOo
set autotoggle enabled
set timeout 60
set netwait 15
set nettimeout 120
set pingtime 30
set pingtimeout 120
set maxconnectionsperhost 256
set threaded_save enabled
set scorelog enabled
set mapsize xysize
set xsize 64
set ysize 64

set victories spacerace

set landm 50
set minp 2
set maxplayers 2
set aifill 6
set generator ISLAND
set landmass 30
set separatepoles ENABLED

# Starting units configuration
set startunits cccwwwx
set startpos DEFAULT
set dispersion 2
set citymindist 3

set wetness 25
set timeout 0
set topology ""
set wrap=
set steepness 12

# Keep AI players so LLM agents can take control of them via /take command
# AI players will be created at startup due to aifill setting above

metaconnection persistent
metamessage New Freeciv-web Multiplayer Game
