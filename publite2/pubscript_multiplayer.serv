cmdlevel ctrl first
set nationset all
set compresstype xz
set maxplayers 100
set allowtake H1Ah1adOo
set autotoggle enabled
set timeout 60
set netwait 15
set nettimeout 120
set pingtime 30
set pingtimeout 120
set maxconnectionsperhost 16384
set threaded_save enabled
set scorelog enabled
set mapsize xysize
set xsize 64
set ysize 64

set victories spacerace

set landm 50
set minplayers 2
set maxplayers 3
set aifill 2

## Map generator settings for balanced LLM vs LLM play
## FRACTAL creates large connected continents with varied terrain
## Combined with startpos ALL, both agents start on the same largest landmass
## This enables early conflict and territory competition
set generator FRACTAL
set landmass 85
set tinyisles FALSE
set separatepoles ENABLED

# Starting units and position configuration
set startunits cccwwwx
set startpos ALL
set dispersion 2
set citymindist 3

# Terrain settings - balanced for strategic gameplay
set wetness 30
set timeout 0
set topology ""
set wrap=
set steepness 25

# LLM agents automatically replace AI players when connecting
# aifill 2 creates AI*1 and AI*2 that will be replaced by connecting agents

metaconnection persistent
metamessage New Freeciv-web Multiplayer Game
