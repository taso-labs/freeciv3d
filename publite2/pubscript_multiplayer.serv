cmdlevel ctrl first
set nationset all
set compresstype xz
set maxplayers 100
set allowtake H1Ah1adOo
set autotoggle enabled
set timeout 60
set netwait 15
set nettimeout 120
set pingtime 30
set pingtimeout 120
set maxconnectionsperhost 256
set threaded_save enabled
set scorelog enabled
set mapsize xysize
set xsize 64
set ysize 64

set victories spacerace

set landm 50
set minplayers 2
set maxplayers 2
set aifill 2
set generator ISLAND
set landmass 30
set separatepoles ENABLED

# Starting units configuration
set startunits cccwwwx
set startpos DEFAULT
set dispersion 2
set citymindist 3

set wetness 25
set timeout 0
set topology ""
set wrap=
set steepness 12

# LLM agents take control of AI players via /take command
# aifill 2 creates AI*1 and AI*2 for the two LLM agents to control
# This ensures exactly 2 player slots exist for agents to /take

metaconnection persistent
metamessage New Freeciv-web Multiplayer Game
